# ============================================================
# VitaCure Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# In Vercel: add each variable via Project → Settings → Environment Variables

# ── Backend API ──────────────────────────────────────────────
# Local development (default if not set):
#   http://localhost:8000/api
# Production (replace with your deployed backend URL):
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# ── Firebase (already embedded in firebase.js — no change needed) ──
